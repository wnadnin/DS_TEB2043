Pratt = 65,
Larson = 57,
Holland = 62,
Paul = 92,
Simu = 92,
Renner = 59
)
scores <- unlist(student_scores)
highest_score <- max(scores)
lowest_score <- min(scores)
average_score <- mean(scores)
